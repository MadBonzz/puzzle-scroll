{
  "expo": {
    "name": "PuzzleScroll",
    "slug": "puzzle-scroll",
    "version": "0.1.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "scheme": "puzzlescroll",
    "icon": "./public/icon-512.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.puzzlescroll.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.puzzlescroll.app",
      "adaptiveIcon": {
        "foregroundImage": "./public/icon-512.png",
        "backgroundColor": "#F7F4EA"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./public/icon-192.png"
    }
  }
}
